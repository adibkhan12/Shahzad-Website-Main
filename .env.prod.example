# Django
DEBUG=0
SECRET_KEY=replace-with-a-strong-50-char-random-string
ALLOWED_HOSTS=shahzadmobile.com,www.shahzadmobile.com
SITE_URL=https://shahzadmobile.com

# Postgres (used by docker-compose to build DATABASE_URL automatically)
POSTGRES_DB=shahzadmobile
POSTGRES_USER=shahzad
POSTGRES_PASSWORD=use-a-strong-password
# DATABASE_URL is auto-built from the above by docker-compose. Override only if needed:
# DATABASE_URL=postgres://shahzad:strong@db:5432/shahzadmobile

# Email (production SMTP — e.g. SendGrid, Mailgun, Amazon SES, your hosting provider)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-smtp-key
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=Shahzad Arshad <sa@shahzadmobile.com>

# Google OAuth (django-allauth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# AWS S3 for product images (re-use your existing bucket)
USE_S3=1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=adib-next-ecommerce
AWS_S3_REGION_NAME=eu-north-1

# Payments
CURRENCY=AED
TAMARA_BASE_URL=https://api.tamara.co
TAMARA_API_KEY=
TABBY_API_URL=https://api.tabby.ai
TABBY_SECRET_KEY=

# One-off Mongo import (leave empty in normal prod)
LEGACY_MONGODB_URI=
LEGACY_MONGODB_DB=

# Set to 1 only on first deploy if you want demo data seeded automatically
SEED_DEMO=0
