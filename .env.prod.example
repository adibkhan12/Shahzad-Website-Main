# Django
DEBUG=0
SECRET_KEY=replace-with-a-strong-50-char-random-string
ALLOWED_HOSTS=shahzadmobile.com,www.shahzadmobile.com
SITE_URL=https://shahzadmobile.com

# Postgres (used by docker-compose to build DATABASE_URL automatically)
POSTGRES_DB=shahzadmobile
POSTGRES_USER=shahzad
POSTGRES_PASSWORD=use-a-strong-password
# DATABASE_URL is auto-built from the above by docker-compose. Override only if needed:
# DATABASE_URL=postgres://shahzad:strong@db:5432/shahzadmobile

# Email (production — Resend SMTP; sign up at https://resend.com)
# Add SPF, DKIM, and DMARC DNS records on shahzadmobile.com per Resend's setup wizard
# before going live, or order confirmations will land in spam.
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_your-resend-api-key
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=Shahzad Arshad <sa@shahzadmobile.com>

# Google OAuth (django-allauth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# AWS S3 for product images (re-use your existing bucket)
USE_S3=1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=adib-next-ecommerce
AWS_S3_REGION_NAME=eu-north-1

# Payments — production
CURRENCY=AED
TAMARA_BASE_URL=https://api.tamara.co
TAMARA_API_KEY=
# Region-specific Tamara keys (preferred over legacy single key above)
TAMARA_API_KEY_UAE=
TAMARA_API_KEY_KSA=
# Tamara webhook auth — provided when you register your webhook ("Notification Token")
TAMARA_NOTIFICATION_TOKEN=

TABBY_API_URL=https://api.tabby.ai
TABBY_SECRET_KEY=
# Region-specific Tabby — UAE uses api.tabby.ai, KSA uses api.tabby.sa
TABBY_API_URL_UAE=https://api.tabby.ai
TABBY_SECRET_KEY_UAE=
TABBY_API_URL_KSA=https://api.tabby.sa
TABBY_SECRET_KEY_KSA=
# Shared secret for the X-Webhook-Auth header you set at Tabby webhook registration
TABBY_WEBHOOK_SECRET=

# One-off Mongo import (leave empty in normal prod)
LEGACY_MONGODB_URI=
LEGACY_MONGODB_DB=

# Set to 1 only on first deploy if you want demo data seeded automatically
SEED_DEMO=0
