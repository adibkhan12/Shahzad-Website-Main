DEBUG=1
SECRET_KEY=change-me-in-prod
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:4200
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CSRF_TRUSTED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

DATABASE_URL=postgres://postgres:postgres@localhost:5432/ecommerce

# Google OAuth (django-allauth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=no-reply@example.com

# AWS S3 (product images)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=adib-next-ecommerce
AWS_S3_REGION_NAME=eu-north-1
USE_S3=0

# Payments — sandbox by default; switch TAMARA_BASE_URL to https://api.tamara.co for prod
CURRENCY=AED
TAMARA_BASE_URL=https://api-sandbox.tamara.co
TAMARA_API_KEY=
# Region-specific keys (preferred over the legacy single key above)
TAMARA_API_KEY_UAE=
TAMARA_API_KEY_KSA=
TAMARA_NOTIFICATION_TOKEN=

TABBY_API_URL_UAE=https://api.tabby.ai
TABBY_SECRET_KEY_UAE=sk_test_0192a999-0d6e-ef6a-bc1b-e018947d0a85
TABBY_PUBLIC_KEY_UAE=pk_test_0192a999-0d6e-ef6a-bc1b-e0188fa81017
TABBY_MERCHANT_CODE_UAE=shahzadarshad
TABBY_API_URL_KSA=https://api.tabby.sa
TABBY_PUBLIC_KEY_KSA=pk_test_0192a999-0d6e-ef6a-bc1b-e0188fa81017
TABBY_SECRET_KEY_KSA=sk_test_0192a999-0d6e-ef6a-bc1b-e018947d0a85
TABBY_MERCHANT_CODE_KSA=shahzadarshadsau

# Stripe — card / Apple Pay / Google Pay
# Get keys from https://dashboard.stripe.com/apikeys
# Use sk_test_ / pk_test_ for QA, sk_live_ / pk_live_ for production
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Get from Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# Legacy Prisma DB (for one-off import)
LEGACY_DATABASE_URL=
