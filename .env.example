DEBUG=1
SECRET_KEY=change-me-in-prod
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://localhost:8000

DATABASE_URL=postgres://postgres:postgres@localhost:5432/ecommerce

# Google OAuth (django-allauth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=no-reply@example.com

# AWS S3 (product images)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=adib-next-ecommerce
AWS_S3_REGION_NAME=eu-north-1
USE_S3=0

# Payments
CURRENCY=AED
TAMARA_BASE_URL=https://api-sandbox.tamara.co
TAMARA_API_KEY=
TABBY_API_URL=https://api.tabby.ai
TABBY_SECRET_KEY=

# Legacy Prisma DB (for one-off import)
LEGACY_DATABASE_URL=
